{
  "version": 2,
  "functions": {
    "app/api/upload/resume/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "app/api/upload/job-description/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "app/api/analyze/route.ts": {
      "memory": 3008,
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cleanup",
      "schedule": "0 */3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "github": {
    "silent": true
  }
}
